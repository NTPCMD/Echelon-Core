DATABASE_URL="postgresql://postgres:postgres@localhost:5432/echelon"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET="replace-me-access"
JWT_REFRESH_SECRET="replace-me-refresh"
OPENAI_API_KEY=""
STRIPE_SECRET_KEY=""
GOHIGHLEVEL_API_KEY=""
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk authentication (apps/web). Get these from https://dashboard.clerk.com
# When both are set, the web app automatically switches to Clerk-powered auth.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/auth/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/auth/register"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/auth/continue?mode=consumer&returnTo=%2Fdashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/auth/continue?mode=consumer&returnTo=%2Fwelcome"
# Enable only after production OAuth credentials are configured in Clerk.
NEXT_PUBLIC_CLERK_SOCIAL_AUTH_ENABLED="false"

# Enable Organizations in Clerk. Each Echelon business maps to one Clerk
# Organization, while the consumer account remains the user's personal context.
