{
  "name": "@echelon/database",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "prisma generate --schema prisma/schema.prisma && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:studio": "prisma studio",
    "seed": "prisma db seed --schema prisma/schema.prisma",
    "db:generate": "prisma generate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
